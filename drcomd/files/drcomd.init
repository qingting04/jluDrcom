#!/bin/sh /etc/rc.common

START=95
USE_PROCD=1

start_service() {
	config_load drcom
	config_get_bool enabled main enabled 0
	[ "$enabled" -eq 1 ] || return 0

	procd_open_instance
	procd_set_param command /usr/sbin/drcomd
	procd_set_param respawn
	procd_close_instance
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "drcom"
}
